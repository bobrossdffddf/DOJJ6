# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# A long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── Discord OAuth2 ─────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# Then go to OAuth2 > General to find these values.

DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The callback URL Discord will redirect to after login.
# In the Developer Portal under OAuth2 > Redirects, add this exact URL.
# For local dev:   http://localhost:5000/auth/discord/callback
# For production:  https://your-domain.com/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# ── Discord Server (Guild) ─────────────────────────────────────────────────────
# The ID of the Discord server users must be a member of to log in.
# Right-click your server name in Discord > Copy Server ID (enable Developer Mode first).
DISCORD_GUILD_ID=000000000000000000

# ── Discord Bot Token ──────────────────────────────────────────────────────────
# Used to look up member roles and accessible channels.
# In the Developer Portal: Bot > Token > Reset Token.
# The bot must be invited to your server with these permissions:
#   - View Channels
#   - Read Message History
DISCORD_BOT_TOKEN=your-bot-token-here

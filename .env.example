PORT=5000
SESSION_SECRET=change-this-in-production

# Discord OAuth2 (from your Discord app at discord.com/developers)
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# Required: the Discord server (guild) ID to load channels from
DISCORD_GUILD_ID=your_discord_server_id

# Required: a bot token for a bot that is in your server
# The bot needs: View Channels, Read Message History
DISCORD_BOT_TOKEN=your_discord_bot_token
